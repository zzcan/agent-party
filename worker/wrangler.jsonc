{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "agentparty-mini",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",
  "durable_objects": {
    "bindings": [{ "name": "CHANNELS", "class_name": "ChannelDO" }]
  },
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["ChannelDO"] }],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "agentparty-mini",
      // D1 由 `wrangler d1 create agentparty-mini` 创建（region WNAM）；测试用 miniflare 不校验此 id
      "database_id": "cba66648-c3ea-4582-8e36-c2842989df3f",
      "migrations_dir": "migrations"
    }
  ],
  "assets": {
    "directory": "../web/dist",
    "binding": "ASSETS",
    "html_handling": "none",
    "not_found_handling": "none",
    "run_worker_first": true
  }
}
